{
  "name": "PC3 Node Mongo DevContainer",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "docker-compose.devcontainer.yml"
  ],
  "service": "app",
  "workspaceFolder": "/workspaces/PC3-CRUD-NODE-MONGODB",
  "shutdownAction": "stopCompose",
  "remoteUser": "root",
  "forwardPorts": [3000, 27017],
  "postCreateCommand": "npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "mongodb.mongodb-vscode"
      ]
    }
  }
}
